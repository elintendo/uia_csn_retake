{
  "server": {
    "port": "8080",
    "database_path": "./logs.db"
  },
  "llm": {
    "provider": "openrouter",
    "api_url": "https://openrouter.ai/api/v1/chat/completions",
    "api_key": "your-openrouter-api-key-here",
    "model": "arcee-ai/trinity-large-preview:free",
    "timeout_seconds": 30,
    "max_tokens": 500
  }
}
